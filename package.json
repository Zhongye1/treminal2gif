{
  "name": "treminal2gif",
  "version": "1.0.0",
  "description": "Cross-platform terminal recording tool that captures terminal sessions and converts them to animated GIFs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "treminal2gif": "./bin/cli.ts"
  },
  "scripts": {
    "start": "ts-node bin/cli.ts",
    "build": "tsc",
    "test": "ts-node bin/cli.ts --help",
    "record": "ts-node bin/cli.ts record",
    "edit": "ts-node bin/cli.ts edit",
    "render": "ts-node bin/cli.ts render",
    "list": "ts-node bin/cli.ts list",
    "config": "ts-node bin/cli.ts config",
    "lint": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"bin/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "terminal",
    "gif",
    "recording",
    "cli",
    "asciinema",
    "screencast"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "bun": "^1.3.10",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "bin",
    "src"
  ]
}
